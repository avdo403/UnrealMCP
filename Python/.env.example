# ============================================================================
# UNREAL MCP SERVER CONFIGURATION
# ============================================================================
# Copy this file to .env and configure for your environment

# Environment (development, production, testing)
UMCP_ENV=development

# ============================================================================
# SERVER SETTINGS
# ============================================================================
UMCP_HOST=127.0.0.1
UMCP_PORT=55557
UMCP_USE_WEBSOCKET=true
UMCP_MAX_CONNECTIONS=10
UMCP_CONNECTION_TIMEOUT=30
UMCP_MAX_RETRIES=5

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
UMCP_ENABLE_CACHING=true
UMCP_CACHE_TTL=3600
UMCP_POOL_SIZE=5

# ============================================================================
# AUTHENTICATION SETTINGS
# ============================================================================
UMCP_ENABLE_AUTH=false
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
UMCP_JWT_SECRET=your-secret-key-here
UMCP_JWT_ALGORITHM=HS256
UMCP_TOKEN_EXPIRY=3600

# ============================================================================
# RATE LIMITING
# ============================================================================
UMCP_ENABLE_RATE_LIMITING=true
UMCP_RATE_LIMIT_REQUESTS=100
UMCP_RATE_LIMIT_WINDOW=60

# ============================================================================
# MONITORING SETTINGS
# ============================================================================
UMCP_ENABLE_METRICS=true
UMCP_ENABLE_TRACING=false
UMCP_METRICS_PORT=9090

# ============================================================================
# LOGGING SETTINGS
# ============================================================================
UMCP_LOG_LEVEL=INFO

# ============================================================================
# CODE EXECUTION SETTINGS
# ============================================================================
UMCP_CODE_EXECUTION_ENABLED=true
UMCP_CODE_EXECUTION_TIMEOUT=30
UMCP_USE_MICROVM=false

# ============================================================================
# REDIS SETTINGS (Optional)
# ============================================================================
UMCP_REDIS_ENABLED=false
UMCP_REDIS_HOST=localhost
UMCP_REDIS_PORT=6379
UMCP_REDIS_DB=0
# UMCP_REDIS_PASSWORD=your-redis-password

# ============================================================================
# UNREAL ENGINE SETTINGS
# ============================================================================
UMCP_UNREAL_HOST=127.0.0.1
UMCP_UNREAL_PORT=55557

# ============================================================================
# FEATURE FLAGS
# ============================================================================
UMCP_ENABLE_PROCEDURAL_GENERATION=true
UMCP_ENABLE_BLUEPRINT_MODIFICATION=true
UMCP_ENABLE_ADVANCED_ANALYSIS=true
