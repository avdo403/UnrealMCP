*.log
unreal_mcp_advanced.log
*.tmp
*.temp

# ============================================================
# IDE & Editor
# ============================================================
.vscode/
.idea/
*.code-workspace
.vs/

# ============================================================
# OS Files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

